# --- Case corpus (the data the app serves) ----------------------------------
# Point to a built corpus directory (contains corpus.db + waveforms/ + manifest.json).
# Build one with: python scripts/build_corpus.py --limit 0 --out data/ecg_corpus
# If unset, the backend auto-discovers the largest COMPLETE data/ecg_corpus* directory.
# Learner-facing startup fails closed when no complete real corpus is present.
# Synthetic fixtures are available only to tests that explicitly opt out.
ECG_CORPUS_ROOT=
ECG_REQUIRE_REAL_DATA=1    # required for learner-facing use; tests may explicitly set 0
ECG_CASE_LIMIT=0           # 0 = no limit

# --- Raw dataset roots (only needed to BUILD the corpus) --------------------
PTBXL_DATA_ROOT=/absolute/path/to/ptb-xl
PTBXL_PLUS_DATA_ROOT=/absolute/path/to/ptb-xl-plus
LEIPZIG_ECG_DATA_ROOT=/absolute/path/to/leipzig-heart-center-ecg
STAFFIII_DATA_ROOT=/absolute/path/to/staff-iii

# Optional multi-source build inputs. MIMIC waveforms live in GCS; the local
# MIMIC-ECG-EXT join is credentialed/research-only and must not be published as
# learner-facing morphology truth without a separate governance approval.
MIMIC_ECG_GCS_PROJECT=example-gcp-project
MIMIC_ECG_GCS_PREFIX=gs://example-private-bucket/mimic-iv-ecg-1.0/physionet.org/files/mimic-iv-ecg/1.0/files
MIMIC_ECG_EXT_LABELS_CSV=/absolute/path/to/records_w_diag_icd10.csv

# --- Learner database -------------------------------------------------------
# Relative sqlite paths are anchored to the project root (single canonical file).
DATABASE_URL=sqlite:///./ecg_learning.db
# Readiness fails when the learner-state filesystem has less than this much
# free space; production also performs a same-filesystem durable write probe.
ECG_MIN_STATE_FREE_BYTES=2147483648
# Required in production. Use a long random value to key privacy-preserving
# registration rate-limit hashes; do not reuse an account password or API key.
AUTH_RATE_LIMIT_SECRET=

# --- LLM tutor --------------------------------------------------------------
# Dev/CI default: mock provider (no key, fully deterministic).
# For real tutoring use an OpenAI-compatible endpoint with a cheap model.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=gpt-5.6-luna    # cost-sensitive/high-volume tutor default; keep deployment-configurable
LLM_BASE_URL=              # e.g. https://api.openai.com/v1

APP_ENV=development
ECG_BACKEND_API_BASE=http://127.0.0.1:8000
