# Installed as /etc/ecg/backend.env with mode 0600. Secret values are fetched
# from Secret Manager by the VM bootstrap; never commit populated copies.
APP_ENV=production
ECG_REQUIRE_REAL_DATA=1
ECG_CASE_LIMIT=0
ECG_MIN_CORPUS_CASES=22497
ECG_MIN_PTBXL_CASES=21799
ECG_MIN_PRACTICE_CASES=5000
ECG_MIN_CLINICAL_CASES=100
ECG_REQUIRE_RELEASE_AUDIT=1
ECG_CORPUS_ROOT=/srv/ecg/corpus
DATABASE_URL=sqlite:////srv/ecg/state/ecg_learning.db
AUTH_RATE_LIMIT_SECRET=replace-from-secret-manager
ECG_ORIGIN_SHARED_SECRET=replace-from-secret-manager
ECG_REQUIRE_RECENT_BACKUP=1
ECG_BACKUP_MAX_AGE_SECONDS=50400
ECG_BACKUP_MARKER_PATH=/srv/ecg/ops/last-backup-success
ECG_MIN_STATE_FREE_BYTES=2147483648
LLM_PROVIDER=openai-compatible
LLM_REQUIRED=1
LLM_API_KEY=replace-from-secret-manager
LLM_MODEL=replace-with-approved-model
LLM_BASE_URL=https://api.openai.com/v1
LLM_MAX_COMPLETION_TOKENS=1200
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_REQUEST_BYTES=131072
LLM_MAX_RESPONSE_BYTES=131072
LLM_AUTHENTICATED_DAILY_LIMIT=60
LLM_GUEST_DAILY_LIMIT=15
LLM_IP_HOURLY_LIMIT=240
LLM_GLOBAL_DAILY_LIMIT=500
