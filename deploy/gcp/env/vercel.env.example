# Vercel Production server-runtime variables. Do not expose these to Preview.
# Previews need an isolated staging backend/key or should fail the build gate.
# Do not prefix either value with NEXT_PUBLIC; browser JavaScript must continue
# using /api/backend.
ECG_BACKEND_API_BASE=https://api.ecg.example.org
ECG_ORIGIN_SHARED_SECRET=the-same-secret-version-used-by-the-backend
# Preview only: set to 1 solely when the two values above point to a separate
# staging backend and secret. Never expose production credentials to previews.
ECG_ALLOW_ISOLATED_PREVIEW_BACKEND=0
