# Root-only host settings used by hydration and backup scripts.
ECG_STATE_DB=/srv/ecg-data/state/ecg_learning.db
ECG_OPS_ROOT=/srv/ecg-data/ops
ECG_BACKUP_GCS_PREFIX=gs://example-private-backup-bucket/sqlite
ECG_CORPUS_GCS_URI=gs://example-private-corpus-bucket/releases/ecg-corpus-2026-07-13.tar.zst
ECG_CORPUS_RELEASE=2026-07-13
ECG_CORPUS_SHA256=replace-with-published-artifact-sha256
ECG_BACKEND_DOMAIN=api.ecg.example.org
ECG_ACME_EMAIL=ops@example.org
GCP_PROJECT_ID=example-gcp-project
ECG_AUTH_SECRET_ID=ecg-auth-rate-limit
ECG_ORIGIN_SECRET_ID=ecg-origin-key
ECG_LLM_PROVIDER=openai-compatible
ECG_LLM_REQUIRED=true
ECG_LLM_SECRET_ID=ecg-llm-api-key
ECG_LLM_MODEL=replace-with-approved-model
ECG_LLM_BASE_URL=https://api.openai.com/v1
ECG_LLM_MAX_COMPLETION_TOKENS=1200
ECG_LLM_REQUEST_TIMEOUT_SECONDS=30
ECG_LLM_MAX_REQUEST_BYTES=131072
ECG_LLM_MAX_RESPONSE_BYTES=131072
ECG_LLM_AUTHENTICATED_DAILY_LIMIT=60
ECG_LLM_GUEST_DAILY_LIMIT=15
ECG_LLM_IP_HOURLY_LIMIT=240
ECG_LLM_GLOBAL_DAILY_LIMIT=500
ECG_BACKUP_MAX_AGE_SECONDS=50400
ECG_MIN_STATE_FREE_BYTES=2147483648
